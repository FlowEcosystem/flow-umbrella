# =============================================================================
# Umbrella Server — environment variables
# =============================================================================
#
# Все переменные читаются Pydantic Settings с префиксом SERVER_.
# В коде они доступны без префикса: Settings.debug, Settings.database_url и т.д.
# =============================================================================


# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# Окружение: dev | test | prod
# Влияет на формат логов, OpenAPI-доки, поведение хендлеров ошибок.
SERVER_ENV=dev

# Debug-режим. В prod ВСЕГДА false.
SERVER_DEBUG=true

# Секретный ключ для подписи токенов, CSRF и т.п.
# Сгенерируй так:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# НЕ коммить реальное значение.
SERVER_SECRET_KEY=change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16)
# -----------------------------------------------------------------------------

# Обязательно схема postgresql+asyncpg:// — валидатор упадёт на обычной postgresql://
# Хост "postgres" = имя сервиса в docker-compose. Для локального запуска вне
# контейнера поменяй на localhost.
SERVER_DATABASE_URL=postgresql+asyncpg://umbrella:umbrella@postgres:5432/umbrella

# Логировать все SQL-запросы (SQLAlchemy echo). true только для отладки —
# в логах будет очень шумно.
SERVER_DATABASE_ECHO=false

# Размер пула соединений.
SERVER_DATABASE_POOL_SIZE=10
SERVER_DATABASE_MAX_OVERFLOW=20


# -----------------------------------------------------------------------------
# PKI (mTLS для агентов)
# -----------------------------------------------------------------------------
# Пути к корневому CA, которым сервер подписывает сертификаты агентов.
# В prod эти пути должны быть примонтированы в контейнер через volume
# с правами 600 для .key.

# dev — создаётся автоматически при старте сервера в папке ./pki/
SERVER_PKI_CA_CERT_PATH=./pki/ca.crt
SERVER_PKI_CA_KEY_PATH=./pki/ca.key
# prod — примонтировать через volume, права 600 на .key
# SERVER_PKI_CA_CERT_PATH=/etc/umbrella/pki/ca.crt
# SERVER_PKI_CA_KEY_PATH=/etc/umbrella/pki/ca.key


# -----------------------------------------------------------------------------
# Agent intervals (секунды)
# -----------------------------------------------------------------------------
# Как часто агенты опрашивают сервер. Значения отдаются агенту в ответе
# на регистрацию/heartbeat — сервер сам диктует ритм.

# Пулинг политик: домены, категории, правила.
SERVER_POLICY_POLL_INTERVAL_SEC=60

# Пулинг команд (reboot, update, run-script): должен быть агрессивнее,
# иначе команды будут долго висеть в очереди.
SERVER_COMMAND_POLL_INTERVAL_SEC=15

# Отправка метрик (CPU, RAM, disk, процессы).
SERVER_METRICS_PUSH_INTERVAL_SEC=60

# -----------------------------------------------------------------------------
# Auth (JWT + refresh cookies)
# -----------------------------------------------------------------------------
SERVER_JWT_ALGORITHM=HS256
SERVER_JWT_ACCESS_TTL_MIN=60
SERVER_JWT_REFRESH_TTL_DAYS=14

# Refresh-cookie политика.
# dev (http://localhost): Secure=false, SameSite=Lax
# prod (https://api.umbrella.su): Secure=true, SameSite=None
SERVER_COOKIE_SECURE=false
SERVER_COOKIE_SAMESITE=lax

# Пусто в dev. В prod тоже пусто (host-only cookie для api.umbrella.su),
# либо .umbrella.su если refresh должен шариться между поддоменами.
SERVER_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Core (обновление CORS)
# -----------------------------------------------------------------------------
# dev: http://localhost:5173
# prod: https://app.umbrella.su
SERVER_CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Agents
# -----------------------------------------------------------------------------
# Сколько дней живёт enrollment-токен. После истечения админ должен
# сгенерировать новый через /v1/agents/{id}/regenerate-enrollment-token.
SERVER_AGENT_ENROLLMENT_TOKEN_TTL_DAYS=7

# mTLS аутентификация агентов через nginx.
# true  — prod: агент аутентифицируется через X-Agent-Cert-CN заголовок (mTLS via nginx)
# false — dev:  fallback на Bearer token (НИКОГДА не использовать в prod!)
SERVER_AGENT_MTLS=true
